# =========================
# COMPOSE
# =========================
# Путь к compose-файлу. Благодаря этому `docker compose <cmd>`, запущенный из корня
# репозитория, сам находит и сам compose-файл, и этот .env — без флагов -f/--env-file.
# (По умолчанию Compose ищет .env рядом с compose-файлом; эта строка переносит точку
# входа в корень, где и лежит .env.)
COMPOSE_FILE=infra/compose/docker-compose.local.yml

# =========================
# BACKEND
# =========================
BACKEND_PORT=3000

# ── Режим запуска (release vs разработка) ──
# SEED_ON_START=true (по умолчанию) — БД пересевается демо-данными при каждом старте
#   (режим разработки/тестов: детерминированные данные).
# SEED_ON_START=false — релизный режим: данные переживают рестарт; onboarding-состояние
#   каталога пользователей (логин ↔ employee_id, роли) восстанавливается из S3-снимка.
# BACKUP_ON_SHUTDOWN=true (по умолчанию) — при аккуратном выключении backend снимает
#   дамп БД (pg_dump) и снимок каталога в S3 (backups/db/..., backups/state/...).
# RESTORE_FROM_BACKUP=true — ОДНОКРАТНО восстановить БД из backups/db/latest.dump
#   на старте (после восстановления верните false; при успехе сидирование
#   пропускается, даже если включено).
# Пустые значения берутся из apps/backend/config.json → "startup".
# SEED_ON_START=
# BACKUP_ON_SHUTDOWN=
# RESTORE_FROM_BACKUP=

# Authentication backend: "mock" (default — verifies passwords against the
# MOCK_AD directory in apps/backend/config.json) or "ad" (real Active Directory
# via LDAP). To switch to AD: set AUTH_MODE=ad and provide the AD connection
# settings below (or the "AD_auth" block in apps/backend/config.json). No code
# changes needed. See docs/ad-integration.md.
AUTH_MODE=mock

# Active Directory connection — only used when AUTH_MODE=ad. These override the
# AD_auth block in apps/backend/config.json. Leave blank to use config.json.
# AD_SERVER=dc01.company.local
# AD_DOMAIN=company.local
# AD_USE_SSL=true
# AD_PORT=636

# Optional: derive the application role from AD group membership.
#   AD_ROLE_SOURCE=system  → role comes from onboarding (default)
#   AD_ROLE_SOURCE=ad      → role is mapped from the user's AD groups
# The group → role mapping (group_role_map) and an optional search_base are set
# in the AD_auth block of apps/backend/config.json. See docs/ad-integration.md.
# AD_ROLE_SOURCE=system
# AD_SEARCH_BASE=

# =========================
# S3 / OBJECT STORAGE (вложения заявок)
# =========================
# По умолчанию используется локальный MinIO, который поднимается вместе со стеком
# (docker compose up). Аккаунт и карта не нужны. Подробности: docs/s3-integration.md
S3_BUCKET_NAME=decision-routing
S3_ENDPOINT_URL=http://minio:9000
# Эндпоинт для подписи ссылок, отдаваемых браузеру. backend ходит в MinIO по
# minio:9000 (внутри docker), но браузер это имя не резолвит — поэтому presigned-
# ссылки подписываются под адрес, доступный с вашей машины (localhost:9000).
# Для облачного S3 не нужно (там endpoint и так публичный) — можно не задавать.
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
# "true" для self-hosted S3 (MinIO) — адресация вида http://endpoint/bucket/key.
S3_FORCE_PATH_STYLE=true

# Чтобы ОТКЛЮЧИТЬ вложения — оставьте S3_BUCKET_NAME пустым (S3_BUCKET_NAME=).
#
# ── Облачный S3 вместо MinIO (например, Cloudflare R2 / AWS S3) ──
# S3_BUCKET_NAME=your-bucket-name
# S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=your-access-key-id
# S3_SECRET_ACCESS_KEY=your-secret-access-key
# S3_REGION=auto
# S3_FORCE_PATH_STYLE=        # обычно не нужен для облачных провайдеров

# =========================
# FRONTEND
# =========================
# Для локального запуска оставьте localhost. Если frontend открыт по удалённому
# IP/домену, он автоматически заменит localhost на hostname открытой страницы.
# Для явной серверной конфигурации укажите публичный адрес backend, например:
# VITE_API_URL=http://192.168.0.25:3000
VITE_API_URL=http://localhost:3000

# =========================
# DATABASE
# =========================

# Для backend внутри Docker Compose:
DB_HOST=db

# Для локального запуска backend вне Docker:
# DB_HOST=localhost

DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=app_db
